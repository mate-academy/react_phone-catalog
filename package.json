{
  "name": "my-react_phone-catalog",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"npm:scss:types\"",
    "build": "tsc -b --noEmit && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "scss:types": "typed-scss-modules \"src/**/*.module.scss\" --watch --aliasPrefixes.@ src"
  },
  "dependencies": {
    "boneyard-js": "^1.8.1",
    "classnames": "^2.5.1",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.15.1",
    "react-tooltip": "^6.0.4",
    "swiper": "^12.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@mate-academy/students-ts-config": "^0.0.4",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cypress": "^15.15.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "typed-scss-modules": "^8.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.12",
    "vite-plugin-checker": "^0.13.0",
    "vite-plugin-svgr": "^5.2.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.tsx": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
