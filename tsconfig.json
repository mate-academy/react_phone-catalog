{
  "extends": "@mate-academy/students-ts-config",
  "include": ["src", "src/**/*", "src/types/**/*.d.ts"],
  "compilerOptions": {
    "sourceMap": false,
    "types": ["node", "cypress"],
    "plugins": [
      { "name": "typescript-plugin-css-modules", "customRenderer": "sass" }
    ],
    "typeRoots": ["./src/types"]
  }
}
