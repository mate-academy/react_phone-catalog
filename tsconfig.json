{
  "extends": "@mate-academy/students-ts-config",
  "include": ["src"],
  "compilerOptions": {
    "sourceMap": false,
    "types": ["node", "cypress"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@hooks/*": ["src/hooks/*"],
      "@modules/*": ["src/modules/*"],
      "@public/*": ["public/*"],
      "@api/*": ["src/api/*"]
    }
  }
}
