{
  "extends": "@mate-academy/students-ts-config",
  "include": [
    "src/App.tsx",
    "src/Root.tsx",
    "src/index.tsx",
    "src/vite-env.d.ts",
    "src/app/**/*",
    "src/images/**/*",
    "src/mainStyles/**/*",
    "src/modules/**/*",
    "src/shared/**/*",
    "src/types/**/*"
  ],
  "compilerOptions": {
    "sourceMap": false,
    "ignoreDeprecations": "6.0",
    "types": ["node", "cypress"]
  }
}
